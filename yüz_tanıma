<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tanı Beni</title>
<style>
  :root{
    --ink:#16140f;
    --paper:#f6f1e6;
    --line:#16140f;
    --accent:#c9512f;
    --accent-soft:#e8c9a8;
    --mono: 'Courier New', monospace;
  }
  *{box-sizing:border-box;}
  body{
    margin:0;
    background:var(--paper);
    color:var(--ink);
    font-family: Georgia, 'Times New Roman', serif;
    min-height:100vh;
    display:flex;
    flex-direction:column;
    align-items:center;
    padding:24px 16px 60px;
  }
  header{
    width:100%;
    max-width:720px;
    text-align:left;
    border-bottom:2px solid var(--line);
    padding-bottom:10px;
    margin-bottom:22px;
  }
  .eyebrow{
    font-family:var(--mono);
    font-size:11px;
    letter-spacing:2px;
    text-transform:uppercase;
    color:var(--accent);
  }
  h1{
    font-size:30px;
    margin:4px 0 2px;
    letter-spacing:-0.5px;
  }
  .sub{
    font-family:var(--mono);
    font-size:12px;
    color:#5a5546;
  }
  .stage{
    position:relative;
    width:100%;
    max-width:560px;
    border:2px solid var(--line);
    background:#000;
    aspect-ratio: 4/3;
    overflow:hidden;
  }
  video, canvas{
    position:absolute;
    top:0;left:0;
    width:100%;
    height:100%;
    object-fit:cover;
  }
  .status{
    width:100%;
    max-width:560px;
    font-family:var(--mono);
    font-size:12px;
    margin-top:10px;
    color:#5a5546;
    min-height:18px;
  }
  .panel{
    width:100%;
    max-width:560px;
    margin-top:18px;
    display:flex;
    flex-direction:column;
    gap:10px;
  }
  .row{
    display:flex;
    gap:10px;
    flex-wrap:wrap;
  }
  input[type=text]{
    flex:1;
    min-width:160px;
    font-family:var(--mono);
    font-size:13px;
    padding:10px 12px;
    border:2px solid var(--line);
    background:transparent;
    color:var(--ink);
  }
  input[type=text]:focus{outline:none; border-color:var(--accent);}
  button{
    font-family:var(--mono);
    font-size:12px;
    letter-spacing:1px;
    text-transform:uppercase;
    padding:10px 16px;
    border:2px solid var(--line);
    background:var(--ink);
    color:var(--paper);
    cursor:pointer;
    transition:transform .08s ease;
  }
  button:hover{transform:translateY(-1px);}
  button:active{transform:translateY(0);}
  button.secondary{
    background:transparent;
    color:var(--ink);
  }
  button.accent{
    background:var(--accent);
    border-color:var(--accent);
    color:var(--paper);
  }
  button:disabled{
    opacity:.4;
    cursor:not-allowed;
    transform:none;
  }
  .people{
    width:100%;
    max-width:560px;
    margin-top:18px;
    border-top:1px solid var(--line);
    padding-top:14px;
  }
  .people h2{
    font-family:var(--mono);
    font-size:11px;
    text-transform:uppercase;
    letter-spacing:2px;
    color:var(--accent);
    margin:0 0 10px;
  }
  .person-chip{
    display:inline-flex;
    align-items:center;
    gap:8px;
    font-family:var(--mono);
    font-size:12px;
    border:1px solid var(--line);
    padding:5px 10px;
    margin:0 8px 8px 0;
  }
  .person-chip button{
    padding:2px 6px;
    font-size:10px;
    background:transparent;
    border:1px solid var(--ink);
    color:var(--ink);
  }
  .hint{
    font-family:var(--mono);
    font-size:11px;
    color:#8a8472;
    line-height:1.6;
  }
  .count-badge{
    font-family:var(--mono);
    font-size:10px;
    background:var(--accent-soft);
    padding:1px 6px;
  }
</style>
</head>
<body>

<header>
  <div class="eyebrow">İstemci-tarafı / tarayıcıda çalışır</div>
  <h1>Tanı Beni</h1>
  <div class="sub">kamerayla yüz öğret → sonra seni tanısın</div>
</header>

<div class="stage" id="stage">
  <video id="video" autoplay muted playsinline></video>
  <canvas id="overlay"></canvas>
</div>

<div class="status" id="status">Modeller yükleniyor…</div>

<div class="panel">
  <div class="row">
    <input type="text" id="nameInput" placeholder="isim yaz (ör. Ahmet)" disabled>
    <button id="learnBtn" class="accent" disabled>Öğret (5 kare)</button>
  </div>
  <div class="row">
    <button id="recognizeBtn" class="secondary" disabled>Tanımayı Başlat</button>
    <button id="stopBtn" class="secondary" disabled>Durdur</button>
  </div>
  <div class="hint">Önce isim yaz ve "Öğret" butonuna bas, kameraya birkaç farklı açıdan bak. Bir veya daha fazla kişi öğretebilirsin. Sonra "Tanımayı Başlat" ile çerçeve üzerinde isim etiketleri görünür. Tüm işlem cihazında çalışır, hiçbir görüntü dışarı gönderilmez.</div>
</div>

<div class="people">
  <h2>Öğretilen Kişiler <span class="count-badge" id="countBadge">0</span></h2>
  <div id="peopleList"></div>
</div>

<script src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
<script>
const MODEL_URL = 'https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/weights';

const video = document.getElementById('video');
const overlay = document.getElementById('overlay');
const statusEl = document.getElementById('status');
const nameInput = document.getElementById('nameInput');
const learnBtn = document.getElementById('learnBtn');
const recognizeBtn = document.getElementById('recognizeBtn');
const stopBtn = document.getElementById('stopBtn');
const peopleList = document.getElementById('peopleList');
const countBadge = document.getElementById('countBadge');

let labeledDescriptors = {}; // name -> array of Float32Array descriptors
let recognizing = false;
let rafId = null;

function setStatus(msg){ statusEl.textContent = msg; }

function renderPeople(){
  peopleList.innerHTML = '';
  const names = Object.keys(labeledDescriptors);
  countBadge.textContent = names.length;
  names.forEach(name => {
    const chip = document.createElement('span');
    chip.className = 'person-chip';
    chip.innerHTML = `${name} (${labeledDescriptors[name].length} örnek) `;
    const del = document.createElement('button');
    del.textContent = 'sil';
    del.onclick = () => { delete labeledDescriptors[name]; renderPeople(); updateRecognizeAvailability(); };
    chip.appendChild(del);
    peopleList.appendChild(chip);
  });
}

function updateRecognizeAvailability(){
  recognizeBtn.disabled = Object.keys(labeledDescriptors).length === 0 || recognizing;
}

async function init(){
  try{
    await faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL);
    await faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL);
    await faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL);
  }catch(e){
    setStatus('Model yüklenemedi. İnternet bağlantını kontrol et.');
    return;
  }

  try{
    const stream = await navigator.mediaDevices.getUserMedia({ video: { width:560, height:420 } });
    video.srcObject = stream;
    await new Promise(res => video.onloadedmetadata = res);
    overlay.width = video.videoWidth;
    overlay.height = video.videoHeight;
  }catch(e){
    setStatus('Kameraya erişilemedi. İzin verdiğinden emin ol.');
    return;
  }

  setStatus('Hazır. Bir isim yaz ve öğret.');
  nameInput.disabled = false;
  learnBtn.disabled = false;
}

learnBtn.onclick = async () => {
  const name = nameInput.value.trim();
  if(!name){ setStatus('Önce bir isim yaz.'); return; }
  learnBtn.disabled = true;
  nameInput.disabled = true;
  const samples = [];
  const total = 5;
  for(let i=0; i<total; i++){
    setStatus(`"${name}" öğreniliyor… kare ${i+1}/${total}`);
    const det = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions())
      .withFaceLandmarks().withFaceDescriptor();
    if(det){
      samples.push(det.descriptor);
      drawBox(det.detection.box, name, '#c9512f');
    } else {
      setStatus('Yüz bulunamadı, kameraya bak ve bekle…');
      i--; // retry this index
    }
    await new Promise(r => setTimeout(r, 500));
  }
  if(!labeledDescriptors[name]) labeledDescriptors[name] = [];
  labeledDescriptors[name].push(...samples);
  renderPeople();
  updateRecognizeAvailability();
  setStatus(`"${name}" öğrenildi (${samples.length} örnek eklendi).`);
  nameInput.value = '';
  nameInput.disabled = false;
  learnBtn.disabled = false;
};

function drawBox(box, label, color){
  const ctx = overlay.getContext('2d');
  ctx.clearRect(0,0,overlay.width, overlay.height);
  ctx.strokeStyle = color;
  ctx.lineWidth = 3;
  ctx.strokeRect(box.x, box.y, box.width, box.height);
  ctx.font = '16px monospace';
  const textW = ctx.measureText(label).width;
  ctx.fillStyle = color;
  ctx.fillRect(box.x, box.y - 22, textW + 12, 22);
  ctx.fillStyle = '#fff';
  ctx.fillText(label, box.x + 6, box.y - 6);
}

function clearOverlay(){
  const ctx = overlay.getContext('2d');
  ctx.clearRect(0,0,overlay.width, overlay.height);
}

recognizeBtn.onclick = () => {
  const names = Object.keys(labeledDescriptors);
  if(names.length === 0) return;

  const faceMatcherData = names.map(name =>
    new faceapi.LabeledFaceDescriptors(name, labeledDescriptors[name])
  );
  const matcher = new faceapi.FaceMatcher(faceMatcherData, 0.55);

  recognizing = true;
  recognizeBtn.disabled = true;
  stopBtn.disabled = false;
  setStatus('Tanıma çalışıyor…');

  async function loop(){
    if(!recognizing) return;
    const detections = await faceapi.detectAllFaces(video, new faceapi.TinyFaceDetectorOptions())
      .withFaceLandmarks().withFaceDescriptors();

    const ctx = overlay.getContext('2d');
    ctx.clearRect(0,0,overlay.width, overlay.height);

    detections.forEach(d => {
      const best = matcher.findBestMatch(d.descriptor);
      const isKnown = best.label !== 'unknown';
      const color = isKnown ? '#2f8a4a' : '#c9512f';
      const label = isKnown ? best.label : 'tanınmadı';
      drawBox(d.detection.box, label, color);
    });

    rafId = requestAnimationFrame(loop);
  }
  loop();
};

stopBtn.onclick = () => {
  recognizing = false;
  if(rafId) cancelAnimationFrame(rafId);
  clearOverlay();
  recognizeBtn.disabled = false;
  stopBtn.disabled = true;
  setStatus('Durduruldu.');
};

init();
</script>

</body>
</html>